{
  "kind": "collectionType",
  "collectionName": "company_contents",
  "info": {
    "singularName": "company-content",
    "pluralName": "company-contents",
    "displayName": "Company Content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "company": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::company.company",
      "inversedBy": "company_content"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "meta_tags": {
      "type": "component",
      "component": "banner.meta-tags",
      "repeatable": false
    },
    "content": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    }
  }
}
