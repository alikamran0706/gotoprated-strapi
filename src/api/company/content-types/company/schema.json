{
  "kind": "collectionType",
  "collectionName": "companies",
  "info": {
    "singularName": "company",
    "pluralName": "companies",
    "displayName": "Company"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "description": {
      "type": "text"
    },
    "website": {
      "type": "string"
    },
    "is_verified": {
      "type": "boolean",
      "default": false
    },
    "company_status": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Approved",
        "Reject"
      ]
    },
    "rejection_reason": {
      "type": "text"
    },
    "company_locations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::company-location.company-location",
      "mappedBy": "company"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "mappedBy": "company"
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq.faq",
      "mappedBy": "company"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "company"
    }
  }
}
