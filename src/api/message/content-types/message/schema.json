{
  "kind": "collectionType",
  "collectionName": "messages",
  "info": {
    "singularName": "message",
    "pluralName": "messages",
    "displayName": "Message"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "sessionId": {
      "type": "string"
    },
    "role": {
      "type": "enumeration",
      "enum": [
        "user",
        "assistant",
        "syestem"
      ]
    },
    "isValid": {
      "type": "boolean",
      "default": true
    },
    "chat": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::chat.chat",
      "inversedBy": "messages"
    },
    "content": {
      "type": "text"
    }
  }
}
