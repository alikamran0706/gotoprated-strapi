{
  "kind": "collectionType",
  "collectionName": "chats",
  "info": {
    "singularName": "chat",
    "pluralName": "chats",
    "displayName": "Chat"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "full_name": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "isGuest": {
      "type": "boolean",
      "default": false
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "chats"
    },
    "lastMessageAt": {
      "type": "datetime"
    },
    "chat_status": {
      "type": "enumeration",
      "enum": [
        "Active",
        "Resolved",
        "Abandoned"
      ]
    },
    "messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::message.message",
      "mappedBy": "chat"
    },
    "sessionId": {
      "type": "string"
    }
  }
}
