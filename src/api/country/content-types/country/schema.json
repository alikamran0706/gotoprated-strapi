{
  "kind": "collectionType",
  "collectionName": "countries",
  "info": {
    "singularName": "country",
    "pluralName": "countries",
    "displayName": "Country"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "country_code": {
      "type": "string"
    },
    "cities": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::city.city",
      "mappedBy": "country"
    },
    "currency": {
      "type": "string"
    },
    "iso_code": {
      "type": "uid"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "flag": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "geo_content": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::geo-content.geo-content",
      "mappedBy": "country"
    },
    "category_contents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category-content.category-content",
      "mappedBy": "country"
    },
    "service_contents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-content.service-content",
      "mappedBy": "country"
    },
    "company_locations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::company-location.company-location",
      "mappedBy": "country"
    }
  }
}
